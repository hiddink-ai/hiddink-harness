{
  "name": "@hiddink-harness/eval-core",
  "version": "0.1.0",
  "description": "Agent evaluation engine for hiddink-harness",
  "type": "module",
  "bin": {
    "eval-core": "./src/cli/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./memory-service": "./src/memory-service.ts",
    "./memory-aggregator": "./src/memory-aggregator.ts",
    "./schema": "./src/db/schema.ts"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.31.9",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
