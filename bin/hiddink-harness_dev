#!/usr/bin/env bash
# Local dev launcher — runs hiddink-harness from src/ with bun hot reload
set -euo pipefail

# Resolve the absolute path of this script even when invoked via symlink
# (e.g. `bun link` creates ~/.bun/bin/hiddink-harness_dev -> repo/bin/hiddink-harness_dev)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

exec bun run "$PROJECT_ROOT/src/cli/index.ts" "$@"
